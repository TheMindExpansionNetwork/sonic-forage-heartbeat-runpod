# Copy relevant lines into web/.env.development when running Next.js
# WITHOUT the Python launcher (npm run dev only).
#
# When using runpod/start.sh or run.py on RunPod, the launcher sets
# NEXT_PUBLIC_POD_BASE_URL automatically from RUNPOD_POD_ID.
#
# Replace YOUR_POD_ID with: echo $RUNPOD_POD_ID

# --- RunPod (remote browser) ---
NEXT_PUBLIC_POD_BASE_URL=https://YOUR_POD_ID-1318.proxy.runpod.net

# --- Local machine (laptop + localhost) ---
# NEXT_PUBLIC_POD_BASE_URL=http://127.0.0.1:1318

# Standalone DEMON: skip queue-admit gates (no daydream queue on this deploy)
NEXT_PUBLIC_LOCAL_MODE=1