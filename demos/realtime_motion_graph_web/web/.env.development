# Local dev default. On RunPod, run.py sets the proxy URL automatically, or
# copy from demos/realtime_motion_graph_web/runpod/env.example.
NEXT_PUBLIC_POD_BASE_URL=http://127.0.0.1:1318
# Bypasses the daydream-webapp queue-admit gates on /api/fixtures and
# /api/loras fetches. Standalone DEMON has no queue; production deploys
# leave this unset.
NEXT_PUBLIC_LOCAL_MODE=1
